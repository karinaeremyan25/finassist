{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build && cd src/app/webapp && npm ci && npm run build",
  "outputDirectory": "src/app/webapp/dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    { "path": "/api/tochka/sync", "schedule": "0 6 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/router" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
