# Telegram
BOT_TOKEN=                   # получить у @BotFather
OWNER_TG_ID=                 # telegram_id Карины (через @userinfobot)
ACCOUNTANT_TG_ID=            # telegram_id бухгалтера
MANAGER_TG_ID=               # CSV если несколько: 12345,67890

# Anthropic
ANTHROPIC_API_KEY=           # console.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6      # классификатор транзакций (детерминированный)
AI_MENTOR_MODEL=claude-opus-4-8     # AI-наставник Mini App (качественный диалог)

# Mini App (Telegram Web App)
WEBAPP_PORT=8080             # порт HTTP-сервера API Mini App
WEBAPP_ALLOWED_ORIGINS=      # CSV разрешённых Origin (пусто = same-origin)

# Database (Supabase)
DATABASE_URL=                # postgres://user:password@host:5432/dbname

# Logging
LOG_LEVEL=info               # error|warn|info|debug
NODE_ENV=production

# Optional
HEALTHCHECKS_URL=            # для мониторинга простоев

# ── Интеграции: платёжные источники ──────────────────────────────────────
# Все поля опциональны. Заполните только нужные источники.
# ВАЖНО: не коммитьте эти значения в git, не логируйте.

# Robokassa — входящие платежи ИП
# Логин магазина (Merchant Login) из личного кабинета Robokassa.
ROBOKASSA_MERCHANT_LOGIN=
# Второй пароль магазина (Password2) — для серверных запросов выписки.
# Настройки → Технические настройки → Пароль #2.
ROBOKASSA_PASSWORD=

# Prodamus — входящие платежи по курсу/клубу
# API-ключ из личного кабинета Продамуса (Настройки → API).
PRODAMUS_API_KEY=

# Точка Банк (Tochka) — расчётный счёт ООО, OAuth 2.0
# Client ID и Client Secret из личного кабинета разработчика Точки.
TOCHKA_CLIENT_ID=
TOCHKA_CLIENT_SECRET=
