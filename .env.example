# Telegram
BOT_TOKEN=                   # получить у @BotFather
OWNER_TG_ID=                 # telegram_id Карины (через @userinfobot)
ACCOUNTANT_TG_ID=            # telegram_id бухгалтера
MANAGER_TG_ID=               # CSV если несколько: 12345,67890

# Anthropic
ANTHROPIC_API_KEY=           # console.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6      # классификатор транзакций (детерминированный)
AI_MENTOR_MODEL=claude-opus-4-8     # AI-наставник Mini App (качественный диалог)

# Mini App (Telegram Web App)
WEBAPP_PORT=8080             # порт HTTP-сервера API Mini App
WEBAPP_ALLOWED_ORIGINS=      # CSV разрешённых Origin (пусто = same-origin)
# Публичный HTTPS-URL Mini App. Обязателен HTTPS — Telegram не откроет http://.
# Зарегистрировать у @BotFather: Bot Settings → Menu Button / Web App.
# Если не задан — команда /app выведет «Mini App временно недоступен».
WEBAPP_URL=                  # https://app.psyhealth.example
# Путь до собранного фронтенда (cd src/app/webapp && npm run build).
# В проде можно указать абсолютный путь к dist. По умолчанию: src/app/webapp/dist
WEBAPP_STATIC_DIR=src/app/webapp/dist

# Database (Supabase)
DATABASE_URL=                # postgres://user:password@host:5432/dbname

# Logging
LOG_LEVEL=info               # error|warn|info|debug
NODE_ENV=production

# Optional
HEALTHCHECKS_URL=            # для мониторинга простоев

# ── Интеграции: платёжные источники ──────────────────────────────────────
# Все поля опциональны. Заполните только нужные источники.
# ВАЖНО: не коммитьте эти значения в git, не логируйте.
#
# Модель интеграций:
#   Tochka  — pull (cron каждые 30 мин, OAuth Open Banking)
#   Robokassa / Prodamus — push (webhook, проверка подписи на нашей стороне)
#
# Robokassa ResultURL (настроить в ЛК Robokassa):
#   Технические настройки → Уведомления → ResultURL =
#   https://<ваш-домен>/api/webhooks/robokassa
#
# Prodamus webhook URL (настроить в ЛК Prodamus):
#   Настройки → Уведомления → URL вебхука =
#   https://<ваш-домен>/api/webhooks/prodamus

# Robokassa — входящие платежи ИП
# Логин магазина (Merchant Login) из личного кабинета Robokassa.
ROBOKASSA_MERCHANT_LOGIN=
# Пароль #2 магазина (Password2 = второй пароль для серверных операций).
# Находится: Настройки → Технические настройки → Пароль #2.
# Используется для проверки подписи ResultURL webhook (НЕ для запросов к API).
ROBOKASSA_PASSWORD=

# Prodamus — входящие платежи по курсу/клубу
# API-ключ из личного кабинета Продамуса (Настройки → API).
# Зарезервирован для REST-запросов (сейчас webhook-only).
PRODAMUS_API_KEY=
# Секретный ключ для проверки HMAC-SHA256 подписи webhook (заголовок Sign).
# Отдельный от API-ключа. Найти: Настройки → Уведомления → Секретный ключ.
PRODAMUS_SECRET_KEY=

# Точка Банк (Tochka) — расчётный счёт ООО, OAuth 2.0 (pull)
# Client ID и Client Secret из личного кабинета разработчика Точки.
TOCHKA_CLIENT_ID=
TOCHKA_CLIENT_SECRET=
